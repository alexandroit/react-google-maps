{
  "name": "@revivejs/react-google-maps",
  "version": "18.0.1",
  "description": "A maintained React 18 wrapper for the Google Maps JavaScript API with versioned docs, marker clustering, and migration-friendly components.",
  "keywords": [
    "react",
    "react-library",
    "typescript",
    "google-maps",
    "google-maps-javascript-api",
    "maps",
    "markerclusterer",
    "info-window",
    "advanced-marker",
    "directions",
    "geocoder",
    "react-google-maps",
    "google-maps-react",
    "wrapper",
    "ui-component",
    "revived",
    "maintained"
  ],
  "homepage": "https://alexandroit.github.io/react-google-maps/",
  "bugs": {
    "url": "https://github.com/alexandroit/react-google-maps/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/react-google-maps.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist docs/react-17 docs/react-18 docs/react-19",
    "docs:install:react-17": "cd docs-src/react-17 && npm install",
    "docs:install:react-18": "cd docs-src/react-18 && npm install",
    "docs:install:react-19": "cd docs-src/react-19 && npm install",
    "build:docs:react-17": "cd docs-src/react-17 && npm run build",
    "build:docs:react-18": "cd docs-src/react-18 && npm run build",
    "build:docs:react-19": "cd docs-src/react-19 && npm run build",
    "build:docs": "npm run build:docs:react-19",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <19.0.0",
    "react-dom": ">=18.0.0 <19.0.0"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "2.6.2"
  },
  "devDependencies": {
    "@types/google.maps": "3.58.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
